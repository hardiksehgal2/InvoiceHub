{
  "compilerOptions": {
    // File layout
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment
    "module": "CommonJS",
    "target": "ES2020",
    "lib": ["ES2020"],

    // Node types
    "types": ["node"],

    // Outputs
    "sourceMap": true,
    "declaration": true,       
    "declarationMap": true,

    // Strict
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "moduleResolution": "bundler"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}